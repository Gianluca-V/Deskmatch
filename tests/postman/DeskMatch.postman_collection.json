{
  "info": {
    "name": "DeskMatch API",
    "description": "Coleccion de pruebas para DeskMatch: Auth, Companies, Workspaces CRUD, Search (OpenSearch) y Health.\n\nFlujo: Register → Login → Create Company → Create Workspace → Search → Delete\n\nVariables configuradas automaticamente por cada request.\n\nPrerrequisitos:\n  - Auth Service corriendo en :5001\n  - Core Service corriendo en :5002\n  - Search Service corriendo en :5004",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "authUrl", "value": "http://localhost:5001" },
    { "key": "coreUrl", "value": "http://localhost:5002" },
    { "key": "searchUrl", "value": "http://localhost:5004" },
    { "key": "accessToken", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "workspaceId", "value": "" },
    { "key": "testEmail", "value": "admin-test-{{$randomInt}}@deskmatch.com" },
    { "key": "testPassword", "value": "Test123!" },
    { "key": "testName", "value": "Admin Test User" }
  ],
  "event": [],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "POST Register Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has accessToken', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "    pm.environment.set('accessToken', json.accessToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"role\": \"Admin\",\n  \"name\": \"{{testName}}\"\n}"
            },
            "url": { "raw": "{{authUrl}}/api/auth/register", "host": ["{{authUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has accessToken', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "    pm.environment.set('accessToken', json.accessToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": { "raw": "{{authUrl}}/api/auth/login", "host": ["{{authUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "GET Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Role is Admin', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.role).to.equal('Admin');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{authUrl}}/api/auth/me", "host": ["{{authUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "2. Companies",
      "item": [
        {
          "name": "POST Create Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('string').and.not.empty;",
                  "    pm.environment.set('companyId', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"DeskMatch Test Company\",\n  \"description\": \"Test company for API tests\"\n}"
            },
            "url": { "raw": "{{coreUrl}}/api/companies", "host": ["{{coreUrl}}"], "path": ["api", "companies"] }
          }
        },
        {
          "name": "GET My Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Company name matches', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.name).to.equal('DeskMatch Test Company');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{coreUrl}}/api/companies/me", "host": ["{{coreUrl}}"], "path": ["api", "companies", "me"] }
          }
        }
      ]
    },
    {
      "name": "3. Workspaces CRUD",
      "item": [
        {
          "name": "POST Create Workspace (with dynamic attrs)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test('Response has id', function () {",
                  "    pm.expect(json.id).to.be.a('string').and.not.empty;",
                  "    pm.environment.set('workspaceId', json.id);",
                  "});",
                  "pm.test('Dynamic attributes are present', function () {",
                  "    pm.expect(json.dynamicAttributes).to.be.an('array').with.lengthOf(3);",
                  "});",
                  "pm.test('Keys are normalized', function () {",
                  "    var keys = json.dynamicAttributes.map(function(a) { return a.key; });",
                  "    pm.expect(keys).to.include.members(['pet-friendly', '24-7-access', 'wifi-speed']);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"name\": \"Cowork Test Buenos Aires\",\n  \"description\": \"Modern coworking space in Palermo with pet-friendly policy\",\n  \"address\": \"Av. Santa Fe 1234\",\n  \"city\": \"Buenos Aires\",\n  \"country\": \"Argentina\",\n  \"latitude\": -34.5888,\n  \"longitude\": -58.4306,\n  \"capacity\": 15,\n  \"pricePerHour\": 25.50,\n  \"amenities\": [\"wifi\", \"ac\", \"coffee\"],\n  \"dynamicAttributes\": [\n    { \"key\": \"Pet Friendly\", \"value\": \"true\" },\n    { \"key\": \"24/7 Access\", \"value\": \"yes\" },\n    { \"key\": \"Wifi Speed\", \"value\": \"300mbps\" }\n  ]\n}"
            },
            "url": { "raw": "{{coreUrl}}/api/workspaces", "host": ["{{coreUrl}}"], "path": ["api", "workspaces"] }
          }
        },
        {
          "name": "POST Create Second Workspace (for search)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.environment.set('workspaceId2', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"name\": \"Premium Office Microcentro\",\n  \"description\": \"High-end executive suites with private offices and meeting rooms\",\n  \"address\": \"Av. Corrientes 800\",\n  \"city\": \"Buenos Aires\",\n  \"country\": \"Argentina\",\n  \"latitude\": -34.6037,\n  \"longitude\": -58.3816,\n  \"capacity\": 50,\n  \"pricePerHour\": 80.00,\n  \"amenities\": [\"wifi\", \"ac\", \"coffee\", \"parking\", \"catering\"],\n  \"dynamicAttributes\": [\n    { \"key\": \"Pet Friendly\", \"value\": false },\n    { \"key\": \"Roof Terrace\", \"value\": \"yes\" }\n  ]\n}"
            },
            "url": { "raw": "{{coreUrl}}/api/workspaces", "host": ["{{coreUrl}}"], "path": ["api", "workspaces"] }
          }
        },
        {
          "name": "GET Workspace by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Name matches created workspace', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.name).to.equal('Cowork Test Buenos Aires');",
                  "});",
                  "pm.test('Dynamic attributes include pet-friendly', function () {",
                  "    var json = pm.response.json();",
                  "    var keys = json.dynamicAttributes.map(function(a) { return a.key; });",
                  "    pm.expect(keys).to.include('pet-friendly');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{coreUrl}}/api/workspaces/{{workspaceId}}",
              "host": ["{{coreUrl}}"],
              "path": ["api", "workspaces", "{{workspaceId}}"]
            }
          }
        },
        {
          "name": "GET List Workspaces",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns paginated response', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array');",
                  "    pm.expect(json.page).to.equal(1);",
                  "    pm.expect(json.totalCount).to.be.at.least(2);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{coreUrl}}/api/workspaces?page=1&pageSize=20",
              "host": ["{{coreUrl}}"],
              "path": ["api", "workspaces"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET List By Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('All workspaces belong to company', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array');",
                  "    pm.expect(json.items.length).to.be.at.least(2);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{coreUrl}}/api/workspaces/company/{{companyId}}",
              "host": ["{{coreUrl}}"],
              "path": ["api", "workspaces", "company", "{{companyId}}"]
            }
          }
        },
        {
          "name": "PUT Update Workspace",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Name is updated', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.name).to.equal('Cowork Test Buenos Aires - Updated');",
                  "});",
                  "pm.test('Dynamic attributes reflect update', function () {",
                  "    var json = pm.response.json();",
                  "    var keys = json.dynamicAttributes.map(function(a) { return a.key; });",
                  "    pm.expect(keys).to.include.members(['pet-friendly', 'new-attr']);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"name\": \"Cowork Test Buenos Aires - Updated\",\n  \"description\": \"Updated description\",\n  \"address\": \"Av. Santa Fe 1234\",\n  \"city\": \"Buenos Aires\",\n  \"country\": \"Argentina\",\n  \"latitude\": -34.5888,\n  \"longitude\": -58.4306,\n  \"capacity\": 20,\n  \"pricePerHour\": 30.00,\n  \"amenities\": [\"wifi\", \"ac\", \"coffee\", \"printer\"],\n  \"dynamicAttributes\": [\n    { \"key\": \"Pet Friendly\", \"value\": \"true\" },\n    { \"key\": \"New Attr\", \"value\": \"test-value\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{coreUrl}}/api/workspaces/{{workspaceId}}",
              "host": ["{{coreUrl}}"],
              "path": ["api", "workspaces", "{{workspaceId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Search (OpenSearch)",
      "item": [
        {
          "name": "GET Search by Text (BM25)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns results for cowork text search', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array').with.lengthOf.at.least(1);",
                  "    pm.expect(json.totalCount).to.be.at.least(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{searchUrl}}/api/search/offices?q=cowork&page=1&pageSize=10",
              "host": ["{{searchUrl}}"],
              "path": ["api", "search", "offices"],
              "query": [
                { "key": "q", "value": "cowork" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET Search Nearby (Geo Distance)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns offices near Palermo', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array').with.lengthOf.at.least(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{searchUrl}}/api/search/nearby?lat=-34.5888&lon=-58.4306&radius=10&pageSize=10",
              "host": ["{{searchUrl}}"],
              "path": ["api", "search", "nearby"],
              "query": [
                { "key": "lat", "value": "-34.5888" },
                { "key": "lon", "value": "-58.4306" },
                { "key": "radius", "value": "10" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET Search with Filters",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('All results are in Buenos Aires', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array');",
                  "    if (json.items.length > 0) {",
                  "        json.items.forEach(function(item) {",
                  "            pm.expect(item.city).to.equal('Buenos Aires');",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{searchUrl}}/api/search/offices?city=Buenos%20Aires&minPrice=10&maxPrice=100&minCapacity=10&amenities=wifi&pageSize=10",
              "host": ["{{searchUrl}}"],
              "path": ["api", "search", "offices"],
              "query": [
                { "key": "city", "value": "Buenos Aires" },
                { "key": "minPrice", "value": "10" },
                { "key": "maxPrice", "value": "100" },
                { "key": "minCapacity", "value": "10" },
                { "key": "amenities", "value": "wifi" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET Search by Dynamic Attribute (pet-friendly)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns pet-friendly workspaces', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.items).to.be.an('array');",
                  "    if (json.items.length > 0) {",
                  "        json.items.forEach(function(item) {",
                  "            if (item.dynamicAttributes) {",
                  "                var petFriendly = item.dynamicAttributes['pet-friendly'];",
                  "            }",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{searchUrl}}/api/search/offices?q=pet-friendly&pageSize=10",
              "host": ["{{searchUrl}}"],
              "path": ["api", "search", "offices"],
              "query": [
                { "key": "q", "value": "pet-friendly" },
                { "key": "pageSize", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "GET Suggest",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns suggestions array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{searchUrl}}/api/search/suggest?q=cow",
              "host": ["{{searchUrl}}"],
              "path": ["api", "search", "suggest"],
              "query": [
                { "key": "q", "value": "cow" }
              ]
            }
          }
        }
      ]
