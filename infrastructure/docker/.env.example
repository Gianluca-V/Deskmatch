# ──────────────────────────────────────────────
# DeskMatch — Docker Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and adjust as needed.
# All variables have safe dev defaults via docker-compose.yml.
# For production, override with real secrets.

# ── JWT ──────────────────────────────────────────
JWT_SECRET=my-dev-secret-change-in-production-32-chars-min
JWT_ISSUER=DeskMatch
JWT_AUDIENCE=DeskMatch
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# ── PostgreSQL ───────────────────────────────────
POSTGRES_USER=deskmatch
POSTGRES_PASSWORD=deskmatch123!

# ── MinIO (S3-compatible storage) ─────────────────
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=deskmatch
STORAGE_USE_SSL=false
STORAGE_PUBLIC_URL=http://localhost:9000

# ── OpenSearch ───────────────────────────────────
OPENSEARCH_INITIAL_ADMIN_PASSWORD=DeskMatch123!

# ── ASP.NET ──────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ── Ollama / AI (opcional, para busqueda semantica) ──
# Dejar vacio para deshabilitar; URL de VM con Ollama
OLLAMA_BASE_URL=
OLLAMA_MODEL=nomic-embed-text-v2-moe
