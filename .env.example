# ─── ASP.NET Core ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# ─── SQL Server ───────────────────────────────────────────────
SQL_SERVER_HOST=187.77.46.31
SQL_SERVER_PORT=15432
SQL_SERVER_DATABASE=deskmatch_development
SQL_SERVER_USER=deskmatch_dev
SQL_SERVER_PASSWORD=9f7875083522ef5e6c74571b303a5349573da64b18566a1e
SQL_SERVER_CONNECTION_STRING=Server=187.77.46.31;Port=15432;Database=deskmatch_development;Username=deskmatch_dev;Password=9f7875083522ef5e6c74571b303a5349573da64b18566a1e;

# ─── JWT / Authentication ─────────────────────────────────────
JWT_SECRET=super-secret-key-change-in-production-min-32-chars!!
JWT_ISSUER=DeskMatch
JWT_AUDIENCE=DeskMatch
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# ─── OpenSearch ───────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_URI=http://${OPENSEARCH_HOST}:${OPENSEARCH_PORT}
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CONNECTION_STRING=${REDIS_HOST}:${REDIS_PORT},password=${REDIS_PASSWORD},ssl=false,abortConnect=false

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/

# ─── Notification (SendGrid / SMTP) ───────────────────────────
NOTIFICATION_PROVIDER=smtp
SENDGRID_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@deskmatch.com
SMTP_FROM_NAME=DeskMatch

# ─── Storage (MinIO / S3) ─────────────────────────────────────
# STORAGE_PROVIDER = minio | local (local guarda en /tmp/DeskMatch/Storage)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=deskmatch
STORAGE_USE_SSL=false
STORAGE_PUBLIC_URL=http://localhost:9000

# ─── Service Ports ────────────────────────────────────────────
API_GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
CORE_SERVICE_PORT=5002
SEARCH_SERVICE_PORT=5003
NOTIFICATION_SERVICE_PORT=5004

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:5174

# ─── Serilog / Logging ────────────────────────────────────────
SERILOG_MINIMUM_LEVEL=Debug
SERILOG_SEQ_URL=http://localhost:5341

# ─── Docker ───────────────────────────────────────────────────
DOCKER_REGISTRY=
DOCKER_TAG=latest
