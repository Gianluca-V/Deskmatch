{
  "Application": {
    "Name": "DeskMatch.ApiGateway"
  },
  "Auth": {
    "Authority": "http://auth-service:5001",
    "Audience": "deskmatch-api"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "core-workspaces-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/workspaces/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "core-companies-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/companies/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "core-reservations-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/reservations/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "core-reviews-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/reviews/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "search-route": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "storage-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/storage/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      },
      "geocode-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/geocode/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-Correlation-Id",
            "Set": "{X-Correlation-Id}"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://auth-service:5001/"
          }
        }
      },
      "core-cluster": {
        "Destinations": {
          "core-destination": {
            "Address": "http://core-service:5002/"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "search-destination": {
            "Address": "http://search-service:5004/"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "notifications-destination": {
            "Address": "http://notification-service:5005/"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Loki": {
      "Uri": "http://localhost:3100"
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  }
}